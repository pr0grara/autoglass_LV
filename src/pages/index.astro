---
import { Image } from 'astro:assets';
import BaseLayout from '@layouts/BaseLayout.astro';
import ServiceAreaMap from '@components/ServiceAreaMap.astro';
import FaqSection from '@components/FaqSection.astro';
import FinalCta from '@components/FinalCta.astro';
import QuoteForm from '@components/QuoteForm.astro';
import CityLinks from '@components/CityLinks.astro';
import { SITE, tel } from '@config/site';
import { SERVICES, type Faq } from '@config/services';
import { serviceUrl } from '../lib/urls';
import { defaultHero } from '../lib/images';
import { faqPage } from '../lib/schema';

const title = `${SITE.region} Mobile Auto Glass & Power Window Repair`;
const description = `Mobile windshield replacement, chip repair, side and rear glass, and power window repair in ${SITE.region}. We come to your home, work, hotel, or parking lot. Call ${SITE.phoneDisplay} for a fast quote.`;

// Homepage FAQs (rendered + FAQ schema via FaqSection / faqPage).
const homeFaqs: Faq[] = [
  {
    q: 'Are you really mobile — you come to me?',
    a: 'Yes. We are a fully mobile service. We bring the glass, adhesive, and tools to your home, work, hotel, or wherever the car is parked anywhere in the Las Vegas valley. There is no shop to drive to.',
  },
  {
    q: 'Do you fix power windows, or just glass?',
    a: 'Both. We replace windshields and side and rear glass, and we also fix power windows that are stuck down, slow, off track, or dead — regulators, motors, and switches. One call covers either problem.',
  },
  {
    q: 'How do I get a quote?',
    a: 'Call us with your vehicle year, make, and model and a quick description of the glass or window issue — that is usually enough for a price. For some windshields we may ask for the VIN or a photo so we order the exact right glass. You can also send a photo through the quote form.',
  },
  {
    q: 'Can you come the same day?',
    a: 'Same-day availability is often possible, especially for broken or stuck windows that leave the car exposed to the heat. Ask when you call and we will give you a real time — not a runaround.',
  },
  {
    q: 'My window is stuck down in the heat — is that urgent?',
    a: 'In Las Vegas, yes. A window that will not close leaves your interior baking, lets dust and monsoon rain in, and leaves the car open in a parking lot. We treat stuck-down windows as a priority and get the glass back up.',
  },
  {
    q: 'What areas do you cover?',
    a: 'Las Vegas, Henderson, North Las Vegas, Summerlin, Spring Valley, Enterprise, Paradise, Green Valley, Winchester, Sunrise Manor, and the surrounding valley. If you are not sure we reach you, call and ask — we likely do.',
  },
];

const jsonLd = faqPage(homeFaqs) ?? [];
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <!-- 1. Simple bold headline — no background image, no subtext -->
  <section class="lp-hero">
    <div class="container">
      <h1>Mobile Auto Glass Repair in {SITE.region}</h1>
    </div>
  </section>

  <!-- 2. Photo + quote form -->
  <section class="section-sm">
    <div class="container split">
      <div class="lp-photo">
        <Image
          src={defaultHero}
          alt={`Mobile auto glass repair in ${SITE.region}`}
          widths={[480, 760, 1000]}
          sizes="(max-width: 920px) 100vw, 560px"
          fetchpriority="high"
          loading="eager"
        />
      </div>
      <QuoteForm source="home-hero" />
    </div>
  </section>

  <!-- 3. Intro / About -->
  <section class="section section-soft" id="about">
    <div class="container prose">
      <h2>We Fix Car Glass and Windows.</h2>
      <p>
        We’re a mobile auto glass and power window crew serving {SITE.region} and the surrounding
        valley. A cracked windshield, a side window smashed in a parking-lot break-in, a rear window
        that let go in the heat, or a power window stuck down with the sun beating in — we handle the
        whole range, and we bring it to wherever the car is parked.
      </p>
      <p>
        Out here, a broken or stuck window isn’t something you want to drive across town to deal with
        in 110-degree heat. Tell us your year, make, and model and what’s wrong, and we’ll give you a
        straight quote and a real time.
      </p>
      <ul class="checklist">
        <li>Windshield replacement &amp; rock-chip repair</li>
        <li>Side window, rear glass &amp; quarter glass</li>
        <li>Power windows that are stuck, slow, off track, or dead</li>
        <li>Regulators, motors &amp; switches — not just the glass</li>
      </ul>
    </div>
  </section>

  <!-- 3. What We Fix — a section per service (alternating rows) -->
  <section class="section section-soft" id="services">
    <div class="container">
      <div class="section-head">
        <h2>What We Fix</h2>
        <p class="lead muted">
          From a freeway rock chip to a window stuck down in the heat, here’s what we handle for
          {SITE.region} drivers.
        </p>
      </div>

      {SERVICES.map((s, i) => (
        <div class:list={['srow', { reverse: i % 2 === 1 }]}>
          <div class="srow-media">
            <a href={serviceUrl(s)}>
              <Image
                src={s.image}
                alt={s.imageAlt}
                widths={[480, 720, 960]}
                sizes="(max-width: 920px) 100vw, 500px"
                loading="lazy"
                style="border-radius:var(--radius);width:100%;"
              />
            </a>
          </div>
          <div class="srow-body">
            {s.emergency && <span class="badge">Emergency</span>}
            <h3><a href={serviceUrl(s)}>{s.name}</a></h3>
            <p>{s.description}</p>
            <p class="srow-actions">
              <a class="btn btn-primary" href={serviceUrl(s)}>More on {s.short} →</a>
              <a class="btn btn-call" href={tel()}>Call {SITE.phoneDisplay}</a>
            </p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- 4. Mobile Service Across Las Vegas (maps + coverage) -->
  <ServiceAreaMap />

  <!-- 5. Window Stuck Down? — heat / security / dust / parking urgency -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <h2>Window Stuck Down? In Las Vegas, That Can’t Wait.</h2>
        <p class="lead muted">
          A power window that won’t roll up is more than an annoyance here — the heat, the dust, and an
          open car in a parking lot make it urgent the same day.
        </p>
      </div>
      <div class="issue-grid">
        <div class="card">
          <h3>The heat cooks the interior</h3>
          <p class="muted">
            With the window down, the cabin bakes to oven temperatures within minutes. We get the glass
            back up so your seats, dash, and electronics aren’t sitting in 110-degree sun all day.
          </p>
        </div>
        <div class="card">
          <h3>Dust and monsoon rain get in</h3>
          <p class="muted">
            Blowing desert dust settles into everything, and late-summer monsoon storms can soak the
            seats through an open window. A window that won’t seal needs fixing before the next storm.
          </p>
        </div>
        <div class="card">
          <h3>An open car is an easy target</h3>
          <p class="muted">
            A window stuck down in a parking lot, garage, or apartment carport leaves your car wide
            open. We prioritize getting it closed and the regulator, motor, or switch repaired.
          </p>
        </div>
      </div>
      <p style="text-align:center;margin-top:24px;">
        <a class="btn btn-call btn-lg" href={tel()}>Call {SITE.phoneDisplay}</a>
      </p>
    </div>
  </section>

  <!-- 6. How It Works -->
  <section class="section section-soft">
    <div class="container">
      <div class="section-head">
        <h2>How It Works</h2>
        <p class="lead muted">Three steps, no runaround.</p>
      </div>
      <div class="issue-grid">
        <div class="card">
          <h3>1. Call or request a quote</h3>
          <p class="muted">
            Call {SITE.phoneDisplay} or send the quote form. Tell us where the car is parked and we’ll
            give you a straight price and a real time.
          </p>
        </div>
        <div class="card">
          <h3>2. Tell us your vehicle &amp; the issue</h3>
          <p class="muted">
            Give us the year, make, and model and what’s wrong — cracked glass, a break-in, or a window
            stuck down. Send a photo if it helps us order the exact right glass.
          </p>
        </div>
        <div class="card">
          <h3>3. We come to you</h3>
          <p class="muted">
            We meet the car at your home, work, hotel, or lot and do the work on-site — most jobs in
            one visit, with the broken glass cleaned up before we leave.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 7. Service area list -->
  <CityLinks
    title={`Service Area — Across the ${SITE.region} Valley`}
    sub="Mobile auto glass and power window repair for every part of the valley we cover."
  />

  <!-- 8. FAQ -->
  <FaqSection faqs={homeFaqs} title="Questions We Hear a Lot" />

  <!-- Final CTA -->
  <FinalCta />
</BaseLayout>

<style>
  .srow-body .badge {
    display: inline-block;
    background: #b42318;
    color: #fff;
    font-size: 11px;
    font-weight: bold;
    text-transform: uppercase;
    padding: 2px 8px;
    border-radius: var(--radius);
    margin-bottom: 8px;
  }
  .srow-body h3 {
    font-size: 1.35rem;
    margin-bottom: 8px;
  }
  .srow-body h3 a {
    color: var(--navy);
    text-decoration: none;
  }
  .srow-body h3 a:hover {
    color: var(--green-dark);
  }
  .srow-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 4px;
  }
</style>
